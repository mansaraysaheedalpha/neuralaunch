# =============================================================================
# NeuraLaunch — Environment variable reference (production + sandbox)
# =============================================================================
# This file documents every environment variable the client app needs. It is
# safe to commit. Never paste real secrets here.
#
# For local development: copy the Paddle block into client/.env.local and
# replace the placeholders with sandbox credentials. All other variables are
# already configured elsewhere per the existing setup.
#
# For production (Vercel): configure all of these in the Vercel dashboard.

# -----------------------------------------------------------------------------
# Paddle — Merchant of Record
# -----------------------------------------------------------------------------
# Sandbox values are used during development. Production values replace these
# only in Vercel environment settings — no code change is required.
#
# Keys starting with pdl_sandbox_... are sandbox-only. Keys starting with
# pdl_live_... are production-only. Never mix them.
#
# PADDLE_API_KEY           — Server-only. Never expose to the browser.
# PADDLE_WEBHOOK_SECRET    — Server-only. Used to verify webhook HMAC.
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN — Browser-safe. Paddle.js initialization.
# NEXT_PUBLIC_PADDLE_ENV   — 'sandbox' (dev/preview) or 'production' (live).

PADDLE_API_KEY=pdl_sandbox_apikey_REPLACE_ME
PADDLE_WEBHOOK_SECRET=pdl_ntfset_REPLACE_ME
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_REPLACE_ME
NEXT_PUBLIC_PADDLE_ENV=sandbox

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# -----------------------------------------------------------------------------
# Upstash Redis (optional — session store fallback)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Authentication (NextAuth v5)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=REPLACE_ME_WITH_A_RANDOM_32_CHAR_STRING

# -----------------------------------------------------------------------------
# OAuth providers
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_MOBILE_CLIENT_ID=
GITHUB_MOBILE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# Research providers (optional)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Background jobs (Inngest)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Public app URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
