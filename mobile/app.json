{
  "expo": {
    "name": "NeuraLaunch",
    "slug": "neuralaunch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "neuralaunch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.neuralaunch.mobile"
    },
    "android": {
      "package": "app.neuralaunch.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#2563EB"
        }
      ]
    ],
    "install": {
      "exclude": ["react-dom"]
    },
    "extra": {
      "apiUrl": "https://startupvalidator.app"
    }
  }
}
