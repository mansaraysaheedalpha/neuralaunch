# ===================================================================
# General & System Files
# ===================================================================
# Ignore OS-generated files
.DS_Store
Thumbs.db

# Ignore IDE and editor directories
.vscode/
.idea/

# Ignore log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ===================================================================
# Frontend (Next.js / TypeScript / Node.js)
# ===================================================================
# Ignore dependency directories — all workspaces + root
node_modules/
client/node_modules/
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/expo-env.d.ts

# Ignore Next.js build output directory
client/.next/

# Ignore other build outputs
client/dist
client/build

# This project uses pnpm exclusively. npm and yarn lockfiles must
# never be committed — they would silently corrupt node_modules
# because of the Prisma postinstall patch (scripts/fix-prisma-pnpm.js).
# See CLAUDE.md and RUNBOOK.md for the full reason.
package-lock.json
yarn.lock

# (Previously a /pnpm-lock.yaml ignore lived here. With packages/* as
# real workspace members, the root lockfile IS the canonical one and
# must be committed. See CLAUDE.md § "Package Manager".)

# Ignore environment variables. These are secret!
# We will create a .env.example file to track which variables are needed.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local


# ===================================================================
# Backend (Python / FastAPI)
# ===================================================================
# Ignore Python virtual environment directory
server/venv/

# Ignore Python cache files
server/__pycache__/
*.pyc

# Ignore testing and coverage artifacts
server/.pytest_cache/
server/htmlcov/

# Ignore secret environment variables for the backend
server/.env*.json
*.docx
*.csv
dataset_analysis.txt
