# NeuraLaunch — example environment variables.
# Copy to .env.local and fill in the real values. .env.local is gitignored.

# Database
DATABASE_URL=postgresql://user:password@host:5432/db

# Upstash Redis (optional in dev — in-memory fallback used when absent)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-at-least-32-characters-of-entropy

# OAuth — web
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — mobile
GITHUB_MOBILE_CLIENT_ID=
GITHUB_MOBILE_CLIENT_SECRET=

# AI services
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Voice transcription
# Primary provider — Deepgram Nova-2 ($0.0043/min).
DEEPGRAM_API_KEY=
# Fallback provider — OpenAI Whisper ($0.006/min). Used only when
# Deepgram is unavailable. Optional: if absent, the fallback chain
# surfaces the Deepgram failure to the caller.
OPENAI_API_KEY=

# Research providers (both optional)
TAVILY_API_KEY=
EXA_API_KEY=

# Background jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
