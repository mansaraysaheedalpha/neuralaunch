# NeuraLaunch — example environment variables.
# Copy to .env.local and fill in the real values. .env.local is gitignored.
#
# Validation source of truth: src/lib/env.ts. The schema there fails the
# build if a required key is missing — keep this file in sync with the
# Zod schema so new contributors don't hit boot errors after pnpm install.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/db

# ---------------------------------------------------------------------------
# Upstash Redis (optional in dev — in-memory fallback used when absent)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-at-least-32-characters-of-entropy

# ---------------------------------------------------------------------------
# OAuth — web
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# LinkedIn — optional. Sign-in button hides when LINKEDIN_CLIENT_ID is empty.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# OAuth — mobile
# Google is shared with the web Google client (additional redirect URI on
# the same OAuth 2.0 Client). GitHub does NOT allow multiple callback URLs
# per OAuth App, so the mobile app uses a separate "NeuraLaunch Mobile"
# OAuth App with its own credentials.
# ---------------------------------------------------------------------------
GITHUB_MOBILE_CLIENT_ID=
GITHUB_MOBILE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# AI services
# ANTHROPIC_API_KEY is required. GOOGLE_AI_API_KEY is the second fallback
# in the model fallback chain — optional; chain stops at Haiku when absent.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ---------------------------------------------------------------------------
# Voice transcription (both optional)
# Primary: Deepgram Nova-2 ($0.0043/min). Fallback: OpenAI Whisper.
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Research providers (both optional — agent's tool list shrinks when
# either key is absent; remaining tool still works)
# ---------------------------------------------------------------------------
TAVILY_API_KEY=
EXA_API_KEY=

# ---------------------------------------------------------------------------
# Transactional email (Resend) — both optional in dev. When unset, email
# sends become no-op log lines so the app boots without configured email.
# Production must set both for billing dunning to actually reach users.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Background jobs (Inngest)
# INNGEST_SIGNING_KEY_FALLBACK is optional and ONLY set during a key
# rotation so the SDK can verify in-flight requests signed by either the
# new or old key. Delete after rotation completes.
# ---------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_SIGNING_KEY_FALLBACK=

# ---------------------------------------------------------------------------
# Public app URL — used by NextAuth, Paddle return URLs, CORS, and
# the validation page absolute-URL builders.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Paddle (Merchant of Record).
# Server keys are REQUIRED in every deployed environment — the app refuses
# to start without them. Public keys are optional for non-billing local dev.
# Cross-validation: PADDLE_API_KEY's prefix (pdl_live_ vs pdl_sandbox_)
# must match NEXT_PUBLIC_PADDLE_ENV; mismatch fails at boot.
# ---------------------------------------------------------------------------
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# ---------------------------------------------------------------------------
# Usage-anomaly alert destination (optional)
# When unset, anomalies fall through to logger.error → Sentry. When set,
# the daily anomaly cron POSTs JSON to this URL (Slack/Discord/generic).
# ---------------------------------------------------------------------------
USAGE_ANOMALY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Sentry — error reporting + distributed tracing. All optional.
# When DSN is unset the SDK silently no-ops and tracing is disabled;
# the app boots without telemetry. Production should set all four.
# SENTRY_AUTH_TOKEN is build-time only (source-map upload).
# SENTRY_ENVIRONMENT and NEXT_PUBLIC_SENTRY_ENVIRONMENT override the
# default NODE_ENV-derived environment tag in Sentry's UI — useful when
# one Vercel project serves multiple environments (preview, staging).
# ---------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
