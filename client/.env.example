# NeuraLaunch — environment variables (example).
#
# Scope of this file: PHASE 1 SENTRY VARS ONLY.
# A broader env contract (DATABASE_URL, Paddle, Anthropic / Google / Exa,
# Inngest, NextAuth, Upstash) is tracked as a separate follow-up ticket
# per docs/migrations/turbopack-migration-log.md § "Sentry Integration".
# Do not add unrelated keys here without filing that ticket.
#
# This file is committed. Real values live in .env.local (gitignored)
# and in Vercel's project env settings — never here.

# ── Sentry — DSN ─────────────────────────────────────────────────────────────
# Project DSN. Same value for both vars; the NEXT_PUBLIC_ prefix exposes the
# DSN to the browser bundle so client-side errors can report. Server-only
# code reads SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<region>.ingest.sentry.io/<project_id>
SENTRY_DSN=https://<key>@<region>.ingest.sentry.io/<project_id>

# ── Sentry — environment label ───────────────────────────────────────────────
# Drives the `environment` filter in Sentry's UI. Leave unset locally to
# fall back to NODE_ENV. In Vercel, set this per env: development / preview /
# production. The NEXT_PUBLIC_ variant is read on the client.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development

# ── Sentry — source-map upload (build-time only, server-side) ────────────────
# Auth token used by withSentryConfig's post-compile hook to upload source
# maps and inject Debug IDs. NEVER expose to the client. NEVER commit.
# When the Vercel-native Sentry integration is wired (Phase 5), Vercel
# manages this token automatically; until then, set it manually in Vercel
# → Project Settings → Environment Variables.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=tabempa-engineering
SENTRY_PROJECT=neuralaunch

# ── Sentry — release tag (auto-injected, do not hardcode) ────────────────────
# withSentryConfig auto-derives this from the git SHA at build time. The
# only reason to set it manually is to override the inferred value (e.g.
# version-tagged releases). Leave commented out under normal operation.
# SENTRY_RELEASE=
