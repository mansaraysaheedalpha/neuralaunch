// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// --- AUTH & USER MODELS (UNCHANGED) ---
model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  conversations     Conversation[]
  discoverySessions DiscoverySession[]
  recommendations   Recommendation[]
  roadmaps          Roadmap[]
  validationPages   ValidationPage[]

  // ----- Concern 5: outcome capture + training-data consent -----
  //
  // Per the deliberation: opt-in must be active and deliberate, not
  // passive. Default is false. The toggle lives in Settings → Privacy
  // and is also surfaced inline the first time the founder is asked
  // for an outcome.
  //
  // Two important properties of this column:
  //   1. Per-row consent on RecommendationOutcome is captured at
  //      submission time, not by reading this field at query time.
  //      Flipping this off does NOT retroactively remove training
  //      records — that requires the explicit deletion sweep
  //      triggered by the toggle handler. The handler deletes every
  //      anonymised record the user has previously written.
  //   2. The consent string also records the moment the founder
  //      first opted in, used by the consent copy version pinning
  //      so we can re-prompt if the consent text materially changes.
  trainingConsent   Boolean                 @default(false)
  trainingConsentAt DateTime?
  outcomes          RecommendationOutcome[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CORE APP MODELS ---
model Conversation {
  id               String            @id @default(cuid())
  title            String
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
  discoverySession DiscoverySession?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Sidebar query is `where: { userId }, orderBy: createdAt desc, take: 100`.
  // The composite index covers both predicates so the planner can use
  // an index-only scan. Stage 7.2 scalability fix.
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  role           String
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /**
   * Provider id of the model that produced this assistant message.
   * Set by the question-stream-fallback orchestrator after the first
   * chunk arrives. Null for user messages and for any assistant
   * message written before fallback was introduced.
   * Known values: 'anthropic-sonnet' | 'anthropic-haiku' | 'google-gemini-flash'
   */
  modelUsed String?

  // The transcript loader queries `where: { conversationId }, orderBy: createdAt asc`.
  // Without this index every conversation transcript would do a full
  // table scan filtered by conversationId. Stage 7.2 scalability fix.
  @@index([conversationId, createdAt])
}

// ==========================================
// PHASE 1 — DISCOVERY ENGINE
// ==========================================

enum DiscoverySessionStatus {
  ACTIVE
  COMPLETE
  EXPIRED
  /**
   * Safety gate triggered — session permanently and irreversibly closed.
   * No further messages accepted. Set by the safetyGate when criminal
   * or harmful intent is detected on ANY message in the session.
   */
  TERMINATED
}

/**
 * DiscoverySession
 * Represents one adaptive interview run for a user.
 * The beliefState JSON column is the typed DiscoveryContext from
 * src/lib/discovery/context-schema.ts — each field carries a value,
 * confidence score, and timestamp.
 */
model DiscoverySession {
  id     String                 @id @default(cuid())
  userId String
  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status DiscoverySessionStatus @default(ACTIVE)

  // Linked conversation — messages are persisted here for sidebar history
  conversationId String?       @unique
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Interview state
  phase            String  @default("ORIENTATION")
  questionCount    Int     @default(0)
  questionsInPhase Int     @default(0)
  activeField      String?
  audienceType     String?

  // Transient interview flags — persisted so sessions survive Redis eviction
  askedFields           Json    @default("[]")
  pricingProbed         Boolean @default(false)
  psychConstraintProbed Boolean @default(false)

  // Timestamp of the last completed turn — used for incomplete session detection
  lastTurnAt DateTime?

  // Current step of the synthesis pipeline — written by the Inngest function so
  // the client can show real progress rather than a time-based animation.
  synthesisStep String?

  // The belief state is the DiscoveryContext — serialised as JSON.
  // Typed accessors in src/lib/discovery/context-schema.ts are the only
  // way to read/write this field. Never mutate it raw.
  beliefState Json

  /**
   * Research-tool audit log — append-only array of ResearchLogEntry
   * objects. Populated by the Interview Agent when the founder
   * mentions something the trigger detector picks up (a competitor
   * name, a regulation, a market claim, a tool reference). Read by
   * the admin debug surface and used as training data for refining
   * the trigger detector and the per-agent query builders.
   *
   * Shape validated by ResearchLogArraySchema in
   * src/lib/research/types.ts. Capped at MAX_RESEARCH_LOG_ENTRIES
   * by the appendResearchLog helper to bound JSONB size.
   */
  researchLog Json @default("[]")

  recommendation Recommendation?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
}

/**
 * Recommendation
 * The single structured output produced by the synthesis engine.
 * Shape is validated against RecommendationSchema (Zod) before write.
 * One-to-one with DiscoverySession.
 */
model Recommendation {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String           @unique
  session   DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ----- Phase awareness (Concern 3 — preparatory data only) -----

  /**
   * Self-describing phase metadata. Pure data, no behaviour.
   * Shape: { phaseNumber, totalPhases, upstream: { discoverySessionId? } }
   * The future orchestration layer reads this to make routing decisions
   * without needing to retrofit storage. Today nothing reads it.
   * See AGENT_ARCHITECTURE_REVIEW.md Concern 3 for the full design.
   */
  phaseContext Json?

  /**
   * The most recent validation signal observed for this recommendation.
   * Mirrors the ValidationReport.signalStrength enum exactly:
   * null      — not yet validated (no published page or no report yet)
   * 'strong'  — strong market signal
   * 'moderate'— moderate market signal
   * 'weak'    — weak signal, ambiguous
   * 'negative'— market actively said no
   * Set by the validation reporting Inngest function when it persists
   * a ValidationReport. Today no downstream behaviour reads this — it
   * is the storage substrate for the future cross-phase coordination
   * layer to read from.
   */
  validationOutcome String?

  // Action shape — drives UI gating for downstream tools (validation page,
  // future Phase 4/5). Set by the synthesis prompt. See RECOMMENDATION_TYPES
  // in src/lib/discovery/constants.ts. Nullable so existing rows from
  // before this column was added remain queryable; UI treats null as
  // "ineligible" by default.
  recommendationType String?

  // ----- Pushback / acceptance (Concerns 1 + 2) -----

  /**
   * Set when the founder explicitly clicks "This is my path — build my
   * roadmap". The act of acceptance is separate from generating the
   * roadmap and from any prior refinements the agent made — only the
   * founder's affirmative click counts.
   */
  acceptedAt DateTime?

  /**
   * Number of pushback rounds (user turns) at the moment of acceptance.
   * 0 means the founder accepted on first read with no pushback.
   * Becomes a key signal for measuring how convincing recommendations are.
   */
  acceptedAtRound Int?

  /**
   * Number of times the founder has un-accepted this recommendation.
   * Each un-accept either came from explicitly clicking "reopen
   * discussion" or implicitly from posting a new pushback message
   * after a previous acceptance.
   */
  unacceptCount Int @default(0)

  /**
   * Optimistic concurrency lock for pushback. Incremented on every
   * write to pushbackHistory. The pushback API performs:
   * updateMany({ where: { id, pushbackVersion: previousVersion }, ... })
   * If the row was modified by another concurrent request between the
   * read and the write, count === 0 and we return 409. Prevents two
   * parallel pushback POSTs from corrupting the history or burning
   * duplicate Opus calls. Same column also serves as the accept
   * endpoint's idempotency lock.
   */
  pushbackVersion Int @default(0)

  /**
   * Full pushback conversation log. Append-only array of turn objects:
   * {
   * role:      'user' | 'agent',
   * content:   string,
   * round:     number,                              // self-describing
   * mode?:     'analytical' | 'fear' | 'lack_of_belief', // agent only
   * action?:   'continue_dialogue' | 'defend' | 'refine' | 'replace' | 'closing', // agent only
   * converging?: boolean,                           // agent only
   * timestamp: string                               // ISO
   * }
   */
  pushbackHistory Json @default("[]")

  /**
   * Snapshots of prior recommendation states. Each entry is a FULL
   * pre-update Recommendation snapshot (not a diff) wrapped with the
   * round number, the agent action that triggered the refresh, and
   * a timestamp:
   * { snapshot: Recommendation, round: number, action: 'refine'|'replace', timestamp: string }
   * Most-recent live state always wins for display; this column powers
   * the "see how this evolved" view. Diffing happens at render time
   * when needed; storing diffs would couple the storage shape to the
   * Recommendation schema and break on every schema change.
   */
  versions Json @default("[]")

  /**
   * Research queries and results persisted for auditability and
   * training data extraction. Shape:
   * [{ query: string, agent: string, timestamp: ISO, answer: string,
   * sources: { title, url, snippet }[], success: boolean }]
   * Populated by the synthesis pipeline's research step (Step 4).
   * Every query Tavily processes is logged with its answer and
   * source list. Future agents (continuation, pushback) can append
   * their own research entries to the same array.
   * This is the QA layer: audit what agents are researching, which
   * queries produce useful results, and the training data source for
   * improving query construction over time.
   */
  researchLog Json @default("[]")

  // ----- Round-7 alternative recommendation (Concern 1, closing move) -----

  /**
   * The alternative recommendation generated at round 7 when the
   * founder's pushback indicated a fundamentally different direction.
   * Self-relation enables a single query to fetch both for the
   * comparison view.
   */
  alternativeRecommendationId String?         @unique
  alternativeRecommendation   Recommendation? @relation("RecommendationAlternative", fields: [alternativeRecommendationId], references: [id])
  primaryRecommendation       Recommendation? @relation("RecommendationAlternative")

  // Core recommendation fields (mirroring RecommendationSchema)
  summary                String @db.Text
  path                   String @db.Text
  reasoning              String @db.Text
  firstThreeSteps        Json // String[]
  timeToFirstResult      String
  risks                  Json // { risk: string; mitigation: string }[]
  assumptions            Json // String[]
  whatWouldMakeThisWrong String @db.Text
  alternativeRejected    Json // { alternative: string; whyNotForThem: string }

  roadmap        Roadmap?
  validationPage ValidationPage?

  // Concern 5 — outcome attestation. Lazy one-to-one. Created when
  // the founder explicitly submits an outcome via one of the three
  // trigger paths.
  outcome RecommendationOutcome?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

enum RoadmapStatus {
  GENERATING
  READY
  FAILED
  /**
   * Roadmap was successfully generated, but the parent Recommendation
   * has since been refined or replaced via the pushback flow. The
   * roadmap content reflects an older recommendation state and should
   * be regenerated. The roadmap viewer renders a banner offering
   * regeneration; the founder can still view the existing content.
   */
  STALE
}

/**
 * Roadmap
 * The structured execution plan produced from a Recommendation + DiscoveryContext.
 * Generated by the Phase 2 roadmap engine. One-to-one with Recommendation.
 * The phases JSON column holds RoadmapPhase[] — validated against RoadmapSchema.
 */
model Roadmap {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationId String         @unique
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  // Phase 3 coordination preparatory data — see Concern 3 in
  // AGENT_ARCHITECTURE_REVIEW.md. Pure metadata, no behaviour today.
  // Shape: { phaseNumber, totalPhases, upstream: { recommendationId, discoverySessionId? } }
  phaseContext Json?

  status RoadmapStatus @default(GENERATING)

  // The full phased plan — validated against RoadmapSchema before write
  phases         Json // RoadmapPhase[]
  closingThought String? @db.Text

  // Derived from beliefState at generation time — stored for display
  weeklyHours Int? // hours/week the user has available
  totalWeeks  Int? // estimated total duration

  // ----- Roadmap Continuation Feature (docs/ROADMAP_CONTINUATION.md) -----

  /**
   * Parking lot — adjacent ideas the founder mentioned during execution
   * that did not belong on the active roadmap. Surfaced in section 5 of
   * the continuation brief at "What's Next?" time.
   *
   * Populated from two sources:
   *   1. The check-in agent, which can attach a parkingLotItem to its
   *      structured response when it detects an adjacent opportunity
   *      in the founder's free-text update. Auto-capture.
   *   2. The manual "Park this idea" route, which the founder hits
   *      explicitly from the roadmap UI.
   *
   * Shape validated by ParkingLotArraySchema in
   * src/lib/continuation/parking-lot-schema.ts. Capped at
   * PARKING_LOT_MAX_ITEMS to bound JSONB size.
   */
  parkingLot Json @default("[]")

  /**
   * Diagnostic chat history — used for Scenarios A and B of the
   * "What's Next?" checkpoint flow. The diagnostic agent runs a short
   * conversation (≤ DIAGNOSTIC_HARD_CAP_TURNS rounds) to identify the
   * blocker before deciding whether to release the founder to the
   * continuation brief or to a re-anchored task adjustment.
   *
   * Append-only array of turns; the runtime shape is enforced via the
   * Zod schemas in src/lib/continuation/diagnostic-schema.ts (Phase 3).
   * Empty when no diagnostic has been run for this roadmap.
   */
  diagnosticHistory Json @default("[]")

  /**
   * Continuation brief — the structured five-section output produced
   * by the continuation engine when "What's Next?" is invoked on a
   * sufficiently-progressed roadmap (Scenario C or D). Generated by
   * Opus, validated against ContinuationBriefSchema before write.
   *
   * NULL until the founder triggers continuation; populated once and
   * read by the continuation reveal page. Regeneration is allowed and
   * overwrites the prior brief — there is no version history at this
   * layer (revisit when production data justifies it).
   */
  continuationBrief Json?

  /**
   * Execution metrics captured at continuation time — actual hours
   * per week derived from check-in cadence vs the founder's stated
   * availability, ratio of estimated-vs-actual durations per task,
   * blocked-task counts, etc. The next-cycle roadmap engine reads
   * this to honestly recalibrate timelines on the next pass.
   *
   * Computed fresh by the continuation engine from RoadmapProgress +
   * checkInHistory; stored on the Roadmap row so the next-cycle
   * generator does not have to re-derive it.
   */
  executionMetrics Json?

  /**
   * Research-tool audit log — append-only array of ResearchLogEntry
   * objects. Populated by the Check-in Agent (when the founder is
   * stuck and needs research help mid-task) and by the Continuation
   * Agent (when the brief generator runs unconditional research
   * before producing forks). Same shape as DiscoverySession.researchLog
   * and Recommendation.researchLog — one safeParse helper covers all.
   *
   * Capped at MAX_RESEARCH_LOG_ENTRIES by the appendResearchLog
   * helper to bound JSONB size on long-running multi-cycle roadmaps.
   */
  researchLog Json @default("[]")

  /**
   * Continuation lifecycle status. NULL when "What's Next?" has never
   * been invoked. Allowed values declared in
   * src/lib/continuation/constants.ts (CONTINUATION_STATUSES):
   *   'CHECKING'         — checkpoint POST in flight
   *   'DIAGNOSING'       — Scenario A or B chat in progress
   *   'GENERATING_BRIEF' — Inngest function generating the brief
   *   'BRIEF_READY'      — brief persisted, awaiting fork pick
   *   'FORK_SELECTED'    — founder picked a fork; next-cycle roadmap is generating
   */
  continuationStatus String?

  /**
   * Self-relation: when a continuation cycle generates a NEW roadmap
   * from a fork pick, the new roadmap's parentRoadmapId points back
   * here. The cycle is open-ended — a roadmap can have arbitrarily
   * many descendants over time, and walking the chain backward gives
   * the full execution history of one founder's strategic journey.
   *
   * ON DELETE SET NULL because deleting an old roadmap must not
   * cascade-delete the new one — the new roadmap carries its own
   * execution evidence and that evidence outlives the parent.
   */
  parentRoadmapId String?
  parentRoadmap   Roadmap?  @relation("RoadmapContinuation", fields: [parentRoadmapId], references: [id], onDelete: SetNull)
  childRoadmaps   Roadmap[] @relation("RoadmapContinuation")

  /**
   * The id of the fork-derived Recommendation produced by the
   * continuation/fork POST route. Set inside the same transaction
   * as the FORK_SELECTED status flip so the linkage and the status
   * commit atomically. Powers the route's idempotency: a retry of
   * the same fork pick (e.g. after a transient inngest.send
   * failure) reads this column, looks up the existing Recommendation,
   * re-fires the event, and returns the existing id rather than
   * creating a duplicate.
   *
   * @unique because exactly one fork can be picked per parent
   * roadmap (the picked-fork state is terminal), so the column
   * doubles as a row-level guard against double-creates.
   */
  forkRecommendationId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ----- Concern 4: roadmap check-in / progress tracking -----
  //
  // Each task object inside the `phases` JSON column gains three
  // additional fields managed by the check-in API:
  //   status:          'not_started' | 'in_progress' | 'completed' | 'blocked'
  //   completedAt:     ISO datetime string | null
  //   checkInHistory:  CheckInEntry[]
  //
  // The roadmap generator does NOT populate these fields. They default
  // to 'not_started' / null / [] when first read by the check-in API
  // and are persisted on the next status change. The summary record
  // below is the queryable analytics surface; never iterate the JSON
  // for aggregate counts.
  progress RoadmapProgress?

  @@index([userId])
  @@index([recommendationId])
  @@index([parentRoadmapId])
}

/**
 * RoadmapProgress
 * Per-roadmap analytics summary updated whenever a task status
 * changes via the check-in API. Stored separately from the roadmap
 * JSON so we never have to parse the full phases array to answer
 * queries like "how many roadmaps have at least one blocked task"
 * or "which roadmaps need a proactive nudge."
 * Created on the first PATCH /status call for a roadmap that does
 * not yet have a row. Maintained atomically alongside the JSON
 * mutation in the same Prisma transaction.
 */
model RoadmapProgress {
  id        String  @id @default(cuid())
  roadmapId String  @unique
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  totalTasks     Int
  completedTasks Int @default(0)
  blockedTasks   Int @default(0)

  /**
   * The most recent moment the founder interacted with this roadmap
   * (status change, check-in submission, or proactive-nudge response).
   * Drives the proactive-nudge cron query and the "X days ago" UI.
   */
  lastActivityAt DateTime @default(now())

  /**
   * The phase number (within the roadmap, NOT the global PHASES enum)
   * the founder is currently working through. Derived from the index
   * of the most recent task that received any check-in.
   */
  currentPhase Int @default(1)

  /**
   * Set to true by the proactive-nudge Inngest function when an
   * in-progress task has exceeded its estimated duration since the
   * last activity. The client clears it on the next check-in submission.
   */
  nudgePending    Boolean   @default(false)
  nudgeLastSentAt DateTime?

  /**
   * The title of the specific task the nudge sweep flagged. The cron
   * function knows which task is stale (by checking startedAt against
   * timeEstimate per in-progress task) but the NudgeBanner component
   * historically re-derived "the first in-progress task" by walking
   * the phases — which could name a different task than the one the
   * cron actually flagged. Persisting the exact title here means the
   * banner reads ground truth.
   *
   * Cleared by the check-in route alongside nudgePending whenever the
   * founder submits any check-in. Falls back to null on legacy rows
   * flagged before this column was added; the banner handles null by
   * walking the phases for backward compatibility.
   */
  staleTaskTitle String?

  // ----- Concern 5: outcome-prompt trigger state -----

  /**
   * Set to true by the daily nudge sweep when:
   * - 50% or more of tasks are complete
   * - lastActivityAt is more than 30 days ago
   * - The parent recommendation does not yet have an outcome row
   * - outcomePromptSkippedAt is null
   * The client reads this on roadmap page load and surfaces the
   * outcome form once. Cleared whenever the founder either submits
   * an outcome or explicitly skips.
   */
  outcomePromptPending Boolean @default(false)

  /**
   * Set when the founder explicitly clicks "skip for now" on the
   * outcome form. Once set, no trigger fires the form again for
   * this roadmap. Respecting the founder's choice not to engage is
   * more important than capturing the data.
   */
  outcomePromptSkippedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nudgePending])
  @@index([lastActivityAt])
  @@index([outcomePromptPending])
}

/**
 * RecommendationOutcome
 * Concern 5: founder-attested outcome of acting on a recommendation.
 * Two parallel records of the outcome live in this row:
 * 1) The full record (outcomeType, freeText, weakPhases, the
 * identifying recommendationId) — always written, owned by the
 * founder, used for their own history view, never used for
 * training.
 * 2) The anonymisedRecord JSON column — written ONLY when
 * consentedToTraining === true at submission time. Stripped of
 * names, emails, phone numbers, and bucketed to country level.
 * Lexical anonymisation only — see consent copy for the disclosure.
 * Hard invariant enforced at write time:
 * consentedToTraining = false  ⇒  anonymisedRecord = null
 * Never bypass.
 * The 24-month TTL on anonymisedRecord is enforced by a daily
 * lifecycle sweep that nulls out anonymisedRecord on rows older
 * than the horizon. The full record stays for the founder's
 * personal history.
 * Retroactive deletion: when a founder flips trainingConsent off,
 * a parallel sweep nulls out anonymisedRecord on every row of
 * theirs that previously consented. The fact that they once
 * consented is preserved (consentedToTraining stays true on the
 * historical row) but the training payload is gone.
 */
model RecommendationOutcome {
  id               String         @id @default(cuid())
  recommendationId String         @unique
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Founder-selected outcome bucket. Mirrors the four types in the
   * spec exactly. Stored as a string so adding a fifth bucket later
   * does not require a migration; the read paths use the typed
   * OUTCOME_TYPES enum from outcome-types.ts as the source of truth.
   * full_success
   * partial_success
   * direction_correct_execution_different
   * did_not_work
   */
  outcomeType String

  /**
   * Optional free-text context. The submission form prompt copy
   * varies by outcomeType — for did_not_work the prompt asks
   * "what would have made this recommendation more accurate" so
   * the answer is diagnostic, not just a failure report.
   */
  freeText String? @db.Text

  /**
   * Phase titles the founder identified as needing the most
   * adjustment. Only populated for partial_success and
   * direction_correct_execution_different outcomes.
   */
  weakPhases String[] @default([])

  /**
   * Captured from User.trainingConsent at submission time.
   * Read-only after write — flipping the user setting later does
   * not retroactively change this value, but it DOES trigger the
   * deletion sweep on anonymisedRecord (see above).
   */
  consentedToTraining Boolean

  /**
   * Anonymised payload for prompt refinement / future fine-tuning.
   * NULL when consentedToTraining is false. Subject to the 24-month
   * TTL via the lifecycle sweep.
   */
  anonymisedRecord Json?

  submittedAt DateTime @default(now())

  @@index([userId])
  @@index([outcomeType])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Phase 3 — Validation Engine
// ---------------------------------------------------------------------------

enum ValidationStatus {
  DRAFT
  LIVE
  ARCHIVED
}

/**
 * ValidationPage
 * A public landing page generated from a Recommendation + Roadmap.
 * Used to validate market interest before the MVP is built.
 * One-to-one with Recommendation. Served at /lp/[slug].
 */
model ValidationPage {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationId String         @unique
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  // Phase 3 coordination preparatory data — see Concern 3 in
  // AGENT_ARCHITECTURE_REVIEW.md. Pure metadata, no behaviour today.
  // Shape: { phaseNumber, totalPhases, upstream: { recommendationId, roadmapId?, discoverySessionId? } }
  phaseContext Json?

  slug          String           @unique // readable URL segment, e.g. "ai-invoicing-tool-accra"
  status        ValidationStatus @default(DRAFT)
  layoutVariant String // 'product' | 'service' | 'marketplace'

  // Claude-generated content — validated against ValidationPageContentSchema
  content Json

  // Generated at publish time — 3 specific distribution channels
  distributionBrief Json?

  // Which distribution channels the user has ticked off
  channelsCompleted String[] @default([])

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  snapshots ValidationSnapshot[]
  report    ValidationReport?
  events    ValidationEvent[]

  @@index([userId])
  @@index([slug])
  @@index([status])
  @@index([recommendationId])
}

/**
 * ValidationSnapshot
 * One record per reporting cycle — raw PostHog analytics data for a page.
 * Written by the Inngest validation-page-reporting function every 24h
 * and on threshold triggers. The interpretation field holds the Sonnet
 * Step 1 output (ValidationInterpretation).
 */
model ValidationSnapshot {
  id               String         @id @default(cuid())
  validationPageId String
  validationPage   ValidationPage @relation(fields: [validationPageId], references: [id], onDelete: Cascade)

  // The founder's target market at the time of this snapshot. Stored per
  // snapshot (not derived at query time) so we can aggregate how threshold
  // dynamics differ across markets without touching live DiscoverySession
  // rows. Used later to calibrate market-aware MIN_VISITORS_FOR_BRIEF etc.
  market String?

  takenAt            DateTime @default(now())
  visitorCount       Int      @default(0)
  uniqueVisitorCount Int      @default(0)
  ctaConversionRate  Float    @default(0) // 0.0–1.0
  featureClicks      Json // { taskId: string, title: string, clicks: number }[]
  surveyResponses    Json // { question: string, answer: string, takenAt: string }[]
  trafficSources     Json // { source: string, count: number }[]
  scrollDepthData    Json // { depth: number, reachedPercentage: number }[]

  // Sonnet Step 1 output — stored so Step 2 can read without re-running
  interpretation Json? // ValidationInterpretation

  @@index([validationPageId])
  @@index([takenAt])
}

/**
 * ValidationReport
 * The committed build brief produced by the Opus Step 2 interpretation agent.
 * Gated behind minimum signal thresholds. One-to-one with ValidationPage
 * (always the most recent report — older reports are preserved in snapshots).
 * When usedForMvp is true, this report is the feature specification for Phase 5.
 */
model ValidationReport {
  id               String         @id @default(cuid())
  validationPageId String         @unique
  validationPage   ValidationPage @relation(fields: [validationPageId], references: [id], onDelete: Cascade)
  snapshotId       String

  // Phase 3 coordination preparatory data — see Concern 3 in
  // AGENT_ARCHITECTURE_REVIEW.md. Pure metadata, no behaviour today.
  // Shape: { phaseNumber, totalPhases, upstream: { validationPageId, recommendationId, roadmapId?, discoverySessionId? } }
  phaseContext Json?

  generatedAt       DateTime @default(now())
  signalStrength    String // 'strong' | 'moderate' | 'weak' | 'negative'
  confirmedFeatures Json // { taskId, title, clicks, percentage, evidence }[]
  rejectedFeatures  Json // { taskId, title, clicks, reason }[]
  surveyInsights    String   @db.Text
  buildBrief        String   @db.Text
  nextAction        String   @db.Text

  // Populated only when signalStrength === 'negative' — what the market
  // contradicted and what adjacent paths the founder could try instead.
  disconfirmedAssumptions Json @default("[]") // string[]
  pivotOptions            Json @default("[]") // { title, rationale }[]

  // True when the user clicks "Mark validation complete" — feeds Phase 5
  usedForMvp Boolean @default(false)

  @@index([validationPageId])
}

/**
 * ValidationEvent
 * Raw analytics event captured from the public /lp/[slug] page.
 * One row per event. Aggregated into ValidationSnapshot on each
 * reporting cycle by the validation-reporting Inngest function.
 * This replaces the PostHog integration — with expected traffic of
 * 50–500 visitors per page lifecycle, persisting events directly to
 * Postgres is cheaper, simpler, and removes an external dependency.
 * The eventType column is a string (not enum) so we can add new event
 * kinds without a migration. Known values:
 * page_view | scroll_depth | exit_intent | feature_click | cta_signup | survey_response
 */
model ValidationEvent {
  id               String         @id @default(cuid())
  validationPageId String
  validationPage   ValidationPage @relation(fields: [validationPageId], references: [id], onDelete: Cascade)

  eventType  String // see docstring
  visitorId  String? // hashed client identifier when available
  properties Json // event-specific payload (taskId, depth, email, answer, etc.)

  createdAt DateTime @default(now())

  @@index([validationPageId, eventType])
  @@index([validationPageId, createdAt])
}
